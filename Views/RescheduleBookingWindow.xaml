<Window x:Class="GymManagement.Views.RescheduleBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chuyển lịch PT"
        Width="460" Height="410"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#D5DAE1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="BorderBrush" Value="#D5DAE1"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="#D5DAE1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Chọn thời gian mới" FontSize="23" FontWeight="SemiBold" Foreground="#20242A"/>
            <TextBlock Text="PT và thời lượng buổi tập sẽ được giữ nguyên."
                       Foreground="#667085" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                CornerRadius="5" Padding="14" Margin="0,18,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Huấn luyện viên" Foreground="#8A929E" FontSize="11"/>
                    <TextBlock x:Name="PtNameText" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Lịch hiện tại" Foreground="#8A929E" FontSize="11"/>
                    <TextBlock x:Name="CurrentTimeText" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Ngày mới" FontWeight="SemiBold"/>
            <DatePicker x:Name="NewDatePicker" Grid.Row="1" Margin="0,6,0,14"
                        SelectedDateChanged="NewDatePicker_SelectedDateChanged"/>
            <TextBlock Grid.Row="2" Text="Giờ bắt đầu mới" FontWeight="SemiBold"/>
            <StackPanel Grid.Row="3">
                <ComboBox x:Name="NewStartTimeComboBox" Margin="0,6,0,0"/>
                <TextBlock x:Name="SlotHintText" Foreground="#667085" FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Đóng" Width="88" Height="34" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Lưu thay đổi" Width="120" Height="34" Background="#DA4453"
                    Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
