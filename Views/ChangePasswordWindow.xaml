<Window x:Class="GymManagement.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu" Width="400" Height="340" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="Đổi mật khẩu" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>
        <TextBlock Text="Mật khẩu hiện tại"/>
        <PasswordBox x:Name="CurrentPasswordBox" Margin="0,4,0,12"/>
        <TextBlock Text="Mật khẩu mới"/>
        <PasswordBox x:Name="NewPasswordBox" Margin="0,4,0,12"/>
        <TextBlock Text="Xác nhận mật khẩu mới"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,4,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Đổi mật khẩu" Width="110" Click="ChangeButton_Click"/>
            <Button Content="Hủy" Width="90" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
