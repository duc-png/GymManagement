<Window x:Class="GymManagement.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change password" Width="400" Height="340" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="Change password" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>
        <TextBlock Text="Current password"/>
        <PasswordBox x:Name="CurrentPasswordBox" Margin="0,4,0,12"/>
        <TextBlock Text="New password"/>
        <PasswordBox x:Name="NewPasswordBox" Margin="0,4,0,12"/>
        <TextBlock Text="Confirm new password"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,4,0,20"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Change" Width="90" Click="ChangeButton_Click"/>
            <Button Content="Cancel" Width="90" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
