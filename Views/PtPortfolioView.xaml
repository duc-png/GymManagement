<UserControl x:Class="GymManagement.Views.PtPortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GymManagement.Converters"
             Background="#F4F6F8">
    <UserControl.Resources>
        <converters:AvatarPathConverter x:Key="AvatarPathConverter"/>
        <Style x:Key="PortfolioButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#DA4453"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#BE3544"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="6" Padding="22,18" Margin="0,0,0,18">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Đội ngũ huấn luyện viên" FontSize="28" FontWeight="SemiBold" Foreground="#20242A"/>
                    <TextBlock Text="Chọn PT phù hợp với mục tiêu và lịch tập của bạn"
                               FontSize="14" Foreground="#667085" Margin="0,7,0,0"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#FDECEE" CornerRadius="4" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PtCountText" FontSize="18" FontWeight="Bold" Foreground="#C93647"/>
                        <TextBlock Text=" PT đang hiển thị" Foreground="#7A2832" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ListView x:Name="PtList" Grid.Row="1" BorderThickness="0" Background="Transparent"
                  HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1" Margin="8" CornerRadius="6">
                        <StackPanel>
                            <Grid Height="190" Background="#E8EBEF">
                                <TextBlock Text="PT" Foreground="#A1A8B2" FontSize="34" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding Avatar, Converter={StaticResource AvatarPathConverter}}"
                                       Stretch="UniformToFill"/>
                                <Border Background="{Binding StatusBackground}" CornerRadius="4" Padding="9,5"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12">
                                    <TextBlock Text="{Binding Status}" Foreground="#344054" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <StackPanel Margin="18">
                                <TextBlock Text="{Binding FullName}" FontSize="20" FontWeight="SemiBold"
                                           Foreground="#20242A" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Specialty}" Foreground="#D13C4C" FontWeight="SemiBold"
                                           Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                                <Border BorderBrush="#EEF0F2" BorderThickness="0,1,0,0" Margin="0,14,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Mức giá" Foreground="#8A929E" FontSize="11"/>
                                        <TextBlock Text="{Binding HourlyRate}" Foreground="#344054" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Portfolio" Foreground="#8A929E" FontSize="11" HorizontalAlignment="Right"/>
                                        <TextBlock Foreground="#344054" FontWeight="SemiBold" Margin="0,3,0,0">
                                            <Run Text="{Binding MediaCount}"/><Run Text=" hình ảnh"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding Rating}" Foreground="#A15C00" Margin="0,12,0,0"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Rating}"/>
                                <Button Content="Xem lịch và đặt PT" Tag="{Binding Id}" Margin="0,16,0,0"
                                        Style="{StaticResource PortfolioButton}" Click="ViewScheduleButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Style>
                <Style TargetType="ListView">
                    <Style.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                                                CornerRadius="6" Padding="30">
                                            <TextBlock Text="Chưa có thông tin huấn luyện viên."
                                                       Foreground="#667085" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>
        </ListView>
    </Grid>
</UserControl>
