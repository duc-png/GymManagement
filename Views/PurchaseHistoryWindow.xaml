<Window x:Class="GymManagement.Views.PurchaseHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch sử giao dịch" Width="1050" Height="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TextBlock Text="Lịch sử giao dịch" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>
        <DataGrid x:Name="InvoicesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice" Width="160" Binding="{Binding InvoiceCode}"/>
                <DataGridTextColumn Header="Date" Width="160" Binding="{Binding CreatedDate}"/>
                <DataGridTextColumn Header="Total" Width="140" Binding="{Binding TotalAmount}"/>
                <DataGridTextColumn Header="Discount %" Width="110" Binding="{Binding DiscountPercent}"/>
                <DataGridTextColumn Header="Final amount" Width="140" Binding="{Binding FinalAmount}"/>
                <DataGridTextColumn Header="Phương thức" Width="170" Binding="{Binding PaymentMethodDisplay}"/>
                <DataGridTextColumn Header="Trạng thái" Width="210" Binding="{Binding PaymentStatusDisplay}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
