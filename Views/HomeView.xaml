<UserControl x:Class="GymManagement.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#E63946"/>
        <SolidColorBrush x:Key="DarkBg" Color="#1D3557"/>
        <SolidColorBrush x:Key="LightGray" Color="#F1FAEE"/>

        <!-- Button Style -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- TOP BAR -->
            <Border Background="{StaticResource DarkBg}" Height="70">
                <Grid Margin="40,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="40" Height="40" Fill="{StaticResource PrimaryColor}"/>
                        <TextBlock Text="GYM MASTER"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Menu -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Content="Thông tin phòng tập" Style="{StaticResource MenuButton}" Click="GymInfoButton_Click"/>
                        <Button Content="PT" Style="{StaticResource MenuButton}" Click="PtButton_Click"/>
                        <Button Content="Công cụ" Style="{StaticResource MenuButton}" Click="ToolsButton_Click"/>
                        <Button Content="Sản phẩm bổ sung" Style="{StaticResource MenuButton}" Click="ProductsButton_Click"/>
                    </StackPanel>

                    <!-- Login Icon -->
                    <Button x:Name="LoginButton"
                            Grid.Column="2"
                            Style="{StaticResource MenuButton}"
                            VerticalAlignment="Center"
                            Click="LoginButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AccountMenu">
                                <MenuItem Header="Thông tin cá nhân" Click="ProfileMenuItem_Click"/>
                                <MenuItem Header="Đổi mật khẩu" Click="ChangePasswordMenuItem_Click"/>
                                <MenuItem Header="Lịch sử mua hàng" Click="PurchaseHistoryMenuItem_Click"/>
                                <MenuItem Header="Gói tập của tôi" Click="MyPackagesMenuItem_Click"/>
                                <MenuItem Header="Đặt lịch PT" Click="BookPtMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Đăng xuất" Click="LogoutMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="32" Height="32" Fill="{StaticResource PrimaryColor}"/>
                            <TextBlock x:Name="LoginText"
                                       Text="Đăng nhập"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- HERO SECTION - GYM IMAGE -->
            <Border Height="500" Margin="0">
                <Grid>
                    <!-- Placeholder gym image -->
                    <Rectangle Fill="#457B9D"/>
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#CC000000" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <!-- Hero Text -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="CHÀO MỪNG ĐÊN GYM MASTER"
                                   Foreground="White"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nơi rèn luyện thể chất hoàn hảo của bạn"
                                   Foreground="White"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"
                                   Opacity="0.9"/>
                        <Button Content="ĐĂNG KÝ NGAY"
                                Background="{StaticResource PrimaryColor}"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="30,15"
                                FontSize="16"
                                FontWeight="Bold"
                                Margin="0,30,0,0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PT SECTION -->
            <StackPanel Margin="60,60,60,40">
                <TextBlock Text="ĐỘI NGŨ HUẤN LUYỆN VIÊN"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource DarkBg}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Đội ngũ PT chuyên nghiệp, tận tâm"
                           FontSize="16"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- PT Cards Grid -->
                <UniformGrid Columns="3" HorizontalAlignment="Center">

                    <!-- PT Card 1 -->
                    <Border Background="White"
                            Margin="15"
                            CornerRadius="8"
                            Width="280">
                        <Border.Effect>
                            <DropShadowEffect Color="#CCCCCC"
                                              BlurRadius="15"
                                              ShadowDepth="3"
                                              Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- PT Image -->
                            <Border Height="280" CornerRadius="8,8,0,0">
                                <Rectangle Fill="#A8DADC"/>
                            </Border>

                            <!-- PT Info -->
                            <StackPanel Margin="20">
                                <TextBlock Text="Phạm Tiến Đạt"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DarkBg}"/>
                                <TextBlock Text="Thể hình &amp; Tăng cơ"
                                           FontSize="14"
                                           Foreground="{StaticResource PrimaryColor}"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="5 năm kinh nghiệm"
                                           FontSize="12"
                                           Foreground="#999"
                                           Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="14"/>
                                    <TextBlock Text="(4.9)" FontSize="12" Foreground="#666" Margin="5,0,0,0"/>
                                </StackPanel>
                                <Button Content="Đặt lịch"
                                        Background="{StaticResource PrimaryColor}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="0,10"
                                        Margin="0,15,0,0"
                                        Cursor="Hand"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PT Card 2 -->
                    <Border Background="White"
                            Margin="15"
                            CornerRadius="8"
                            Width="280">
                        <Border.Effect>
                            <DropShadowEffect Color="#CCCCCC" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Height="280" CornerRadius="8,8,0,0">
                                <Rectangle Fill="#F4A261"/>
                            </Border>
                            <StackPanel Margin="20">
                                <TextBlock Text="Hoàng Yến"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DarkBg}"/>
                                <TextBlock Text="Yoga &amp; Giảm cân"
                                           FontSize="14"
                                           Foreground="{StaticResource PrimaryColor}"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="7 năm kinh nghiệm"
                                           FontSize="12"
                                           Foreground="#999"
                                           Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="14"/>
                                    <TextBlock Text="(5.0)" FontSize="12" Foreground="#666" Margin="5,0,0,0"/>
                                </StackPanel>
                                <Button Content="Đặt lịch"
                                        Background="{StaticResource PrimaryColor}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="0,10"
                                        Margin="0,15,0,0"
                                        Cursor="Hand"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PT Card 3 -->
                    <Border Background="White"
                            Margin="15"
                            CornerRadius="8"
                            Width="280">
                        <Border.Effect>
                            <DropShadowEffect Color="#CCCCCC" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Height="280" CornerRadius="8,8,0,0">
                                <Rectangle Fill="#2A9D8F"/>
                            </Border>
                            <StackPanel Margin="20">
                                <TextBlock Text="Trần Minh Khang"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource DarkBg}"/>
                                <TextBlock Text="Cardio &amp; Sức bền"
                                           FontSize="14"
                                           Foreground="{StaticResource PrimaryColor}"
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="4 năm kinh nghiệm"
                                           FontSize="12"
                                           Foreground="#999"
                                           Margin="0,10,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="⭐⭐⭐⭐" FontSize="14"/>
                                    <TextBlock Text="(4.7)" FontSize="12" Foreground="#666" Margin="5,0,0,0"/>
                                </StackPanel>
                                <Button Content="Đặt lịch"
                                        Background="{StaticResource PrimaryColor}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="0,10"
                                        Margin="0,15,0,0"
                                        Cursor="Hand"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>

            <!-- REVIEWS SECTION -->
            <Border Background="{StaticResource LightGray}" Padding="60,60">
                <StackPanel>
                    <TextBlock Text="ĐÁNH GIÁ TỪ HỘI VIÊN"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkBg}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Những phản hồi chân thực từ học viên"
                               FontSize="16"
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <!-- Review Cards -->
                    <UniformGrid Columns="2">

                        <!-- Review 1 -->
                        <Border Background="White"
                                Margin="15"
                                Padding="30"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#CCCCCC" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Ellipse Width="50" Height="50" Fill="#457B9D"/>
                                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Nguyễn Văn A"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DarkBg}"/>
                                        <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="14" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Phòng gym rất hiện đại, đội ngũ PT nhiệt tình. Tôi đã giảm được 10kg sau 3 tháng tập luyện tại đây!"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#555"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <!-- Review 2 -->
                        <Border Background="White"
                                Margin="15"
                                Padding="30"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#CCCCCC" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Ellipse Width="50" Height="50" Fill="#E63946"/>
                                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Trần Thị B"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DarkBg}"/>
                                        <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="14" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Cô PT Hoàng Yến dạy yoga rất tốt, tôi cảm thấy cơ thể linh hoạt hơn nhiều. Không gian phòng tập sạch sẽ và thoáng mát."
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#555"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <!-- Review 3 -->
                        <Border Background="White"
                                Margin="15"
                                Padding="30"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#CCCCCC" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Ellipse Width="50" Height="50" Fill="#2A9D8F"/>
                                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Lê Minh C"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DarkBg}"/>
                                        <TextBlock Text="⭐⭐⭐⭐" FontSize="14" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Thiết bị đầy đủ, giá cả hợp lý. PT Tiến Đạt hướng dẫn tận tình, form tập chuẩn. Rất đáng để đầu tư!"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#555"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <!-- Review 4 -->
                        <Border Background="White"
                                Margin="15"
                                Padding="30"
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#CCCCCC" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Ellipse Width="50" Height="50" Fill="#F4A261"/>
                                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Phạm Thị D"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DarkBg}"/>
                                        <TextBlock Text="⭐⭐⭐⭐⭐" FontSize="14" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Lần đầu tập gym nhưng được hướng dẫn kỹ càng từ cơ bản. Không khí tập luyện rất tích cực và năng động!"
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#555"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- FOOTER -->
            <Border Background="{StaticResource DarkBg}" Padding="60,40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="GYM MASTER"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>
                        <TextBlock Text="Địa chỉ: 123 Đường ABC, Quận 1, TP.HCM"
                                   Foreground="#AAA"
                                   FontSize="13"
                                   Margin="0,5"/>
                        <TextBlock Text="Hotline: 0901234567"
                                   Foreground="#AAA"
                                   FontSize="13"
                                   Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="LIÊN KẾT NHANH"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>
                        <TextBlock Text="Về chúng tôi" Foreground="#AAA" FontSize="13" Margin="0,5"/>
                        <TextBlock Text="Gói tập" Foreground="#AAA" FontSize="13" Margin="0,5"/>
                        <TextBlock Text="Liên hệ" Foreground="#AAA" FontSize="13" Margin="0,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GIỜ MỞ CỬA"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>
                        <TextBlock Text="Thứ 2 - Thứ 6: 6:00 - 22:00" Foreground="#AAA" FontSize="13" Margin="0,5"/>
                        <TextBlock Text="Thứ 7 - CN: 7:00 - 21:00" Foreground="#AAA" FontSize="13" Margin="0,5"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
