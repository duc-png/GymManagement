<UserControl x:Class="GymManagement.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GymManagement.Converters"
             Background="#F5F5F5">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#E63946"/>
        <SolidColorBrush x:Key="DarkBg" Color="#1D2939"/>
        <SolidColorBrush x:Key="LightGray" Color="#F1F3F5"/>
        <converters:AvatarPathConverter x:Key="AvatarPathConverter"/>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="HomeScrollViewer" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="{StaticResource DarkBg}" Height="70">
                <Grid Margin="40,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="40" Height="40" Fill="{StaticResource PrimaryColor}"/>
                        <TextBlock Text="GYM MASTER" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="Đội ngũ PT" Style="{StaticResource MenuButton}" Click="PtSectionButton_Click"/>
                        <Button Content="Đánh giá" Style="{StaticResource MenuButton}" Click="FeedbackSectionButton_Click"/>
                    </StackPanel>
                    <Button x:Name="LoginButton" Grid.Column="2" Style="{StaticResource MenuButton}" VerticalAlignment="Center" Click="LoginButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="AccountMenu">
                                <MenuItem Header="Thông tin cá nhân" Click="ProfileMenuItem_Click"/>
                                <MenuItem Header="Đổi mật khẩu" Click="ChangePasswordMenuItem_Click"/>
                                <MenuItem Header="Lịch sử mua hàng" Click="PurchaseHistoryMenuItem_Click"/>
                                <MenuItem Header="Gói tập của tôi" Click="MyPackagesMenuItem_Click"/>
                                <MenuItem Header="Giỏ hàng" Click="MyCartMenuItem_Click"/>
                                <MenuItem x:Name="FeedbackMenuItem" Header="Đánh giá" Click="FeedbackMenuItem_Click"/>
                                <MenuItem Header="Đặt lịch PT" Click="BookPtMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="Đăng xuất" Click="LogoutMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="32" Height="32" Fill="{StaticResource PrimaryColor}"/>
                            <TextBlock x:Name="LoginText" Text="Đăng nhập" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Background="#293B52" MinHeight="410">
                <Grid Margin="70,46">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="GYM MASTER" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Không gian tập luyện hiện đại, PT chuyên nghiệp và lịch tập linh hoạt" Foreground="#E7ECF2" FontSize="19" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                            <TextBlock Text="Mở cửa 06:00 - 22:00" Foreground="White" FontSize="15"/>
                            <TextBlock Text="  |  " Foreground="#98A2B3"/>
                            <TextBlock Text="Hotline 0901 234 567" Foreground="White" FontSize="15"/>
                            <TextBlock Text="  |  " Foreground="#98A2B3"/>
                            <TextBlock Text="123 Đường ABC, Quận 1, TP.HCM" Foreground="White" FontSize="15"/>
                        </StackPanel>
                    </StackPanel>
                    <UniformGrid Grid.Row="1" Columns="3" Margin="150,30,150,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="PtCountText" Text="0" Foreground="{StaticResource PrimaryColor}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Huấn luyện viên" Foreground="#D0D5DD"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="ActiveMemberCountText" Text="0" Foreground="{StaticResource PrimaryColor}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hội viên đang hoạt động" Foreground="#D0D5DD"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="AverageRatingText" Text="--" Foreground="{StaticResource PrimaryColor}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Điểm đánh giá" Foreground="#D0D5DD"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <StackPanel x:Name="PtSection" Margin="60,52,60,44">
                <TextBlock Text="ĐỘI NGŨ HUẤN LUYỆN VIÊN" FontSize="30" FontWeight="Bold" Foreground="{StaticResource DarkBg}" HorizontalAlignment="Center"/>
                <TextBlock Text="Thông tin và đánh giá được cập nhật trực tiếp từ hệ thống" FontSize="15" Foreground="#667085" HorizontalAlignment="Center" Margin="0,8,0,28"/>
                <ItemsControl x:Name="PtItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Margin="10" CornerRadius="6">
                                <StackPanel>
                                    <Grid Height="220" Background="#E5E7EB">
                                        <TextBlock Text="PT" Foreground="#98A2B3" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Avatar, Converter={StaticResource AvatarPathConverter}}" Stretch="UniformToFill"/>
                                    </Grid>
                                    <StackPanel Margin="18">
                                        <TextBlock Text="{Binding FullName}" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource DarkBg}"/>
                                        <TextBlock Text="{Binding Specialty}" Foreground="{StaticResource PrimaryColor}" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#667085" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding HourlyRateText}" Foreground="#344054" FontWeight="SemiBold" Margin="0,7,0,0"/>
                                        <TextBlock Text="{Binding RatingText}" Foreground="#B54708" Margin="0,7,0,0"/>
                                        <Button Content="Xem lịch PT" Tag="{Binding Id}" Height="34" Margin="0,14,0,0" Click="PtCardBookButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Style.Triggers>
                                <Trigger Property="HasItems" Value="False"><Setter Property="Template"><Setter.Value><ControlTemplate><TextBlock Text="Chưa có thông tin huấn luyện viên." Foreground="#667085" HorizontalAlignment="Center" Margin="0,20"/></ControlTemplate></Setter.Value></Setter></Trigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>
            </StackPanel>

            <Border x:Name="FeedbackSection" Background="{StaticResource LightGray}" Padding="60,48">
                <StackPanel>
                    <TextBlock Text="ĐÁNH GIÁ TỪ HỘI VIÊN" FontSize="30" FontWeight="Bold" Foreground="{StaticResource DarkBg}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Những phản hồi mới nhất đã gửi trên hệ thống" FontSize="15" Foreground="#667085" HorizontalAlignment="Center" Margin="0,8,0,28"/>
                    <ItemsControl x:Name="FeedbackItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#E4E7EC" BorderThickness="1" Margin="10" Padding="22" CornerRadius="6">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MemberName}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource DarkBg}"/>
                                                <TextBlock Text="{Binding TargetName}" Foreground="#667085" FontSize="12" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SubmittedDateText}" HorizontalAlignment="Right" Foreground="#98A2B3" FontSize="12"/>
                                        </Grid>
                                        <TextBlock Text="{Binding RatingText}" Foreground="#B54708" Margin="0,12,0,0"/>
                                        <TextBlock Text="{Binding Comment}" TextWrapping="Wrap" FontSize="14" Foreground="#475467" LineHeight="21" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <Trigger Property="HasItems" Value="False"><Setter Property="Template"><Setter.Value><ControlTemplate><TextBlock Text="Chưa có đánh giá nào." Foreground="#667085" HorizontalAlignment="Center" Margin="0,20"/></ControlTemplate></Setter.Value></Setter></Trigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkBg}" Padding="60,36">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="GYM MASTER" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="123 Đường ABC, Quận 1, TP.HCM" Foreground="#98A2B3" Margin="0,4"/>
                        <TextBlock Text="Hotline: 0901 234 567" Foreground="#98A2B3" Margin="0,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="DỊCH VỤ" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Gói tập linh hoạt" Foreground="#98A2B3" Margin="0,4"/>
                        <TextBlock Text="Huấn luyện viên cá nhân" Foreground="#98A2B3" Margin="0,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GIỜ MỞ CỬA" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="Thứ 2 - Thứ 6: 06:00 - 22:00" Foreground="#98A2B3" Margin="0,4"/>
                        <TextBlock Text="Thứ 7 - Chủ nhật: 07:00 - 21:00" Foreground="#98A2B3" Margin="0,4"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
