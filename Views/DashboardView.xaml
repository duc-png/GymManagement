<UserControl x:Class="GymManagement.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="1" Columns="3" Rows="2">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Members" Foreground="#6B7280"/>
                    <TextBlock Text="0" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Active packages" Foreground="#6B7280"/>
                    <TextBlock Text="0" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Today bookings" Foreground="#6B7280"/>
                    <TextBlock Text="0" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Revenue" Foreground="#6B7280"/>
                    <TextBlock Text="0 VND" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Equipment" Foreground="#6B7280"/>
                    <TextBlock Text="0" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>
                    <TextBlock Text="Feedback" Foreground="#6B7280"/>
                    <TextBlock Text="0" FontSize="32" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
