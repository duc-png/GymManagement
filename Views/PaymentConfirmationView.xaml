<UserControl x:Class="GymManagement.Views.PaymentConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                CornerRadius="6" Padding="20,16" Margin="0,0,0,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Xác nhận thanh toán" FontSize="26" FontWeight="SemiBold" Foreground="#20242A"/>
                    <TextBlock Text="Kiểm tra tiền mặt tại quầy hoặc giao dịch chuyển khoản trước khi xác nhận."
                               Foreground="#667085" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#FFF4E5" CornerRadius="4" Padding="12,7" Margin="0,0,10,0">
                        <TextBlock x:Name="PendingCountText" Foreground="#8A4B08" FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="Làm mới" Width="90" Height="34" Click="RefreshButton_Click"/>
                    <Button Content="Từ chối" Width="90" Height="34" Margin="8,0,0,0"
                            Click="RejectButton_Click"/>
                    <Button Content="Xác nhận đã nhận tiền" Width="155" Height="34" Margin="8,0,0,0"
                            Background="#2E7D4F" Foreground="White" BorderThickness="0"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="PaymentsGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                  SelectionChanged="PaymentsGrid_SelectionChanged"
                  BorderBrush="#DDE1E6" Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã yêu cầu" Width="190" Binding="{Binding InvoiceCode}"/>
                <DataGridTextColumn Header="Hội viên" Width="*" Binding="{Binding Member.FullName}"/>
                <DataGridTextColumn Header="Ngày tạo" Width="145" Binding="{Binding CreatedDate, StringFormat=dd/MM/yyyy HH:mm}"/>
                <DataGridTextColumn Header="Phương thức" Width="170" Binding="{Binding PaymentMethodDisplay}"/>
                <DataGridTextColumn Header="Trạng thái" Width="210" Binding="{Binding PaymentStatusDisplay}"/>
                <DataGridTextColumn Header="Số tiền" Width="140" Binding="{Binding FinalAmount, StringFormat={}{0:N0} đ}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="5" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="DetailTitleText" Text="Chi tiết yêu cầu" FontSize="16"
                           FontWeight="SemiBold" Margin="0,0,0,10"/>
                <DataGrid x:Name="DetailsGrid" Grid.Row="1" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nội dung" Width="*" Binding="{Binding ItemName}"/>
                        <DataGridTextColumn Header="Loại" Width="110" Binding="{Binding ItemType}"/>
                        <DataGridTextColumn Header="Số lượng" Width="90" Binding="{Binding Quantity}"/>
                        <DataGridTextColumn Header="Đơn giá" Width="140" Binding="{Binding UnitPrice, StringFormat={}{0:N0} đ}"/>
                        <DataGridTextColumn Header="Thành tiền" Width="150" Binding="{Binding TotalPrice, StringFormat={}{0:N0} đ}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
