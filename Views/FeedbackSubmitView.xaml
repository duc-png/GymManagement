<UserControl x:Class="GymManagement.Views.FeedbackSubmitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#D5DAE1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="StarRatingButton" TargetType="RadioButton">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="Foreground" Value="#C7CCD3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="StarBorder" Background="#F7F8FA" BorderBrush="#E1E5EA"
                                BorderThickness="1" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="25"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StarBorder" Property="BorderBrush" Value="#E0A020"/>
                                <Setter Property="Foreground" Value="#E0A020"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="StarBorder" Property="Background" Value="#FFF7DF"/>
                                <Setter TargetName="StarBorder" Property="BorderBrush" Value="#E0A020"/>
                                <Setter Property="Foreground" Value="#D89100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubmitFeedbackButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="145"/>
            <Setter Property="Background" Value="#DA4453"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#BE3544"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#E1E5EA" BorderThickness="1"
                CornerRadius="6" Padding="22,17" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Chia sẻ trải nghiệm" FontSize="28" FontWeight="SemiBold" Foreground="#20242A"/>
                <TextBlock Text="Đánh giá của bạn giúp chất lượng dịch vụ và đội ngũ PT tốt hơn."
                           Foreground="#667085" Margin="0,7,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" MaxWidth="920" HorizontalAlignment="Center" VerticalAlignment="Top"
                Background="White" BorderBrush="#E1E5EA" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#293B52" CornerRadius="6,0,0,6" Padding="26">
                    <StackPanel>
                        <TextBlock Text="PHẢN HỒI" Foreground="#E7ECF2" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="Mỗi nhận xét đều có giá trị." Foreground="White" FontSize="24"
                                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,14,0,0"/>
                        <Border BorderBrush="#50647C" BorderThickness="0,1,0,0" Margin="0,24,0,20"/>
                        <TextBlock Text="Bạn có thể đánh giá PT sau khi hoàn thành buổi tập, hoặc đánh giá phòng tập sau khi mua gói."
                                   Foreground="#D0D8E2" TextWrapping="Wrap" LineHeight="21"/>
                        <TextBlock x:Name="EligiblePtCountText" Foreground="#FFCF70" FontWeight="SemiBold"
                                   TextWrapping="Wrap" Margin="0,24,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="30,25">
                    <TextBlock Text="Loại đánh giá" FontWeight="SemiBold" Foreground="#344054"/>
                    <ComboBox x:Name="TypeComboBox" Margin="0,7,0,18"
                              SelectionChanged="TypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Đánh giá huấn luyện viên" Tag="PT"/>
                        <ComboBoxItem Content="Đánh giá phòng tập" Tag="Facility"/>
                    </ComboBox>

                    <Grid Margin="0,0,0,18">
                        <StackPanel x:Name="PtPanel">
                            <TextBlock Text="Huấn luyện viên" FontWeight="SemiBold" Foreground="#344054"/>
                            <ComboBox x:Name="PtComboBox" DisplayMemberPath="FullName" SelectedValuePath="Id"
                                      Margin="0,7,0,0"/>
                            <TextBlock x:Name="PtEligibilityText" Foreground="#667085" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="FacilityRequirementText"
                                   Text="Áp dụng cho hội viên đã mua ít nhất một gói tập."
                                   Foreground="#667085" TextWrapping="Wrap" Visibility="Collapsed"/>
                    </Grid>

                    <TextBlock Text="Mức độ hài lòng" FontWeight="SemiBold" Foreground="#344054"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,18">
                        <RadioButton x:Name="Star1Button" GroupName="Rating" Content="★" Tag="1"
                                     ToolTip="1 sao" Style="{StaticResource StarRatingButton}" Checked="RatingButton_Checked"/>
                        <RadioButton x:Name="Star2Button" GroupName="Rating" Content="★" Tag="2"
                                     ToolTip="2 sao" Style="{StaticResource StarRatingButton}" Checked="RatingButton_Checked"/>
                        <RadioButton x:Name="Star3Button" GroupName="Rating" Content="★" Tag="3"
                                     ToolTip="3 sao" Style="{StaticResource StarRatingButton}" Checked="RatingButton_Checked"/>
                        <RadioButton x:Name="Star4Button" GroupName="Rating" Content="★" Tag="4"
                                     ToolTip="4 sao" Style="{StaticResource StarRatingButton}" Checked="RatingButton_Checked"/>
                        <RadioButton x:Name="Star5Button" GroupName="Rating" Content="★" Tag="5"
                                     ToolTip="5 sao" Style="{StaticResource StarRatingButton}" Checked="RatingButton_Checked"/>
                        <TextBlock x:Name="RatingText" Text="5/5" Foreground="#9A6400" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </StackPanel>

                    <Grid>
                        <TextBlock Text="Nhận xét" FontWeight="SemiBold" Foreground="#344054"/>
                        <TextBlock x:Name="CommentCountText" Text="0 ký tự" HorizontalAlignment="Right"
                                   Foreground="#98A2B3" FontSize="12"/>
                    </Grid>
                    <TextBox x:Name="CommentTextBox" Height="135" Margin="0,7,0,0" Padding="10,8"
                             BorderBrush="#D5DAE1" VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             TextChanged="CommentTextBox_TextChanged"/>

                    <Button x:Name="SubmitButton" Content="Gửi đánh giá" HorizontalAlignment="Right"
                            Margin="0,22,0,0" Style="{StaticResource SubmitFeedbackButton}"
                            Click="SubmitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
