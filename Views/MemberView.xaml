<UserControl x:Class="GymManagement.Views.MemberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Members" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Add" Width="90" Margin="8,0,0,0" Click="AddButton_Click"/>
                <Button Content="Edit" Width="90" Margin="8,0,0,0" Click="EditButton_Click"/>
                <Button Content="Delete" Width="90" Margin="8,0,0,0" Click="DeleteButton_Click"/>
            </StackPanel>
            <TextBox x:Name="SearchTextBox" Height="34" Width="280"
                     VerticalContentAlignment="Center" Padding="10,0"
                     TextChanged="SearchTextBox_TextChanged"/>
        </DockPanel>

        <Border Grid.Row="2" x:Name="EditorPanel" Visibility="Collapsed"
                BorderBrush="#DDD" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Full name"/>
                    <TextBox x:Name="FullNameTextBox" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Phone"/>
                    <TextBox x:Name="PhoneTextBox" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Email"/>
                    <TextBox x:Name="EmailTextBox" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="Gender"/>
                    <ComboBox x:Name="GenderComboBox" Margin="0,4,0,0">
                        <ComboBoxItem Content="Male"/>
                        <ComboBoxItem Content="Female"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Save" Width="75" Click="SaveButton_Click"/>
                    <Button Content="Cancel" Width="75" Margin="8,0,0,0" Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="MembersGrid" Grid.Row="3" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" SelectionChanged="MembersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Width="140" Binding="{Binding MemberCode}"/>
                <DataGridTextColumn Header="Full name" Width="*" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Phone" Width="160" Binding="{Binding PhoneNumber}"/>
                <DataGridTextColumn Header="Email" Width="220" Binding="{Binding Email}"/>
                <DataGridTextColumn Header="Gender" Width="100" Binding="{Binding Gender}"/>
                <DataGridTextColumn Header="Registered" Width="130" Binding="{Binding RegistrationDate}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
