<Window x:Class="GymManagement.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Width="460" Height="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Personal information" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,18"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Member code"/>
            <TextBox x:Name="MemberCodeTextBox" IsReadOnly="True" Margin="0,4,0,12"/>
            <TextBlock Text="Username"/>
            <TextBox x:Name="UsernameTextBox" IsReadOnly="True" Margin="0,4,0,12"/>
            <TextBlock Text="Full name"/>
            <TextBox x:Name="FullNameTextBox" Margin="0,4,0,12"/>
            <TextBlock Text="Phone"/>
            <TextBox x:Name="PhoneTextBox" Margin="0,4,0,12"/>
            <TextBlock Text="Email (read only)"/>
            <TextBox x:Name="EmailTextBox" IsReadOnly="True" Margin="0,4,0,12"/>
            <TextBlock Text="Date of birth"/>
            <DatePicker x:Name="DateOfBirthPicker" Margin="0,4,0,12"/>
            <TextBlock Text="Gender"/>
            <ComboBox x:Name="GenderComboBox" Margin="0,4,0,0">
                <ComboBoxItem Content="Male"/>
                <ComboBoxItem Content="Female"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Save" Width="90" Click="SaveButton_Click"/>
            <Button Content="Close" Width="90" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
