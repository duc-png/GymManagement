<Window x:Class="GymManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập — Gym Master"
        Width="460" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#E63946"/>
        <SolidColorBrush x:Key="Dark" Color="#1D3557"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PwdBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Dark}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="GYM MASTER"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Hệ thống quản lý phòng tập"
                           Foreground="#A0AEC0"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl x:Name="TabControl" Grid.Row="1" BorderThickness="0" Background="White">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="Foreground" Value="#666"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0,0,0,3"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB ĐĂNG NHẬP -->
            <TabItem Header="Đăng nhập">
                <StackPanel Margin="40,30,40,20">
                    <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameTextBox" Style="{StaticResource InputBox}"/>

                    <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#555" Margin="0,16,0,6"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource PwdBox}"/>

                    <Button Content="ĐĂNG NHẬP"
                            Style="{StaticResource PrimaryBtn}"
                            Margin="0,24,0,0"
                            Click="LoginButton_Click"/>

                    <TextBlock x:Name="LoginErrorText"
                               Foreground="#E63946"
                               FontSize="13"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </TabItem>

            <!-- TAB ĐĂNG KÝ -->
            <TabItem Header="Đăng ký">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,20,40,20">
                        <TextBlock Text="Họ và tên" FontSize="13" Foreground="#555" Margin="0,0,0,6"/>
                        <TextBox x:Name="RegFullNameTextBox" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="Tên đăng nhập" FontSize="13" Foreground="#555" Margin="0,12,0,6"/>
                        <TextBox x:Name="RegUsernameTextBox" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="Mật khẩu" FontSize="13" Foreground="#555" Margin="0,12,0,6"/>
                        <PasswordBox x:Name="RegPasswordBox" Style="{StaticResource PwdBox}"/>

                        <TextBlock Text="Số điện thoại" FontSize="13" Foreground="#555" Margin="0,12,0,6"/>
                        <TextBox x:Name="RegPhoneTextBox" Style="{StaticResource InputBox}"/>

                        <Button Content="ĐĂNG KÝ"
                                Style="{StaticResource PrimaryBtn}"
                                Margin="0,20,0,0"
                                Click="RegisterButton_Click"/>

                        <TextBlock x:Name="RegErrorText"
                                   Foreground="#E63946"
                                   FontSize="13"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
