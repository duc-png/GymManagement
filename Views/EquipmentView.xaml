<UserControl x:Class="GymManagement.Views.EquipmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Equipment" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Add" Width="90" Margin="8,0,0,0"/>
                <Button Content="Edit" Width="90" Margin="8,0,0,0"/>
                <Button Content="Maintain" Width="90" Margin="8,0,0,0"/>
            </StackPanel>
            <TextBox Height="34" Width="280" VerticalContentAlignment="Center" Padding="10,0" Text="Search equipment"/>
        </DockPanel>
        <DataGrid Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Equipment" Width="*" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Type" Width="160" Binding="{Binding Type}"/>
                <DataGridTextColumn Header="Condition" Width="140" Binding="{Binding Condition}"/>
                <DataGridTextColumn Header="Status" Width="120" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
