<Window x:Class="GymManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GymManagement.Views"
        Title="Gym Management" Height="900" Width="1400"
        Background="#F2F2F2" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryPink" Color="#DA4453"/>
        <SolidColorBrush x:Key="DarkBg" Color="#282828"/>

        <Style x:Key="ReadMoreBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryPink}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border x:Name="WorkspaceBar" DockPanel.Dock="Top" Background="{StaticResource DarkBg}" Padding="12" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button Content="Home" Click="HomeButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Packages" Click="PackagesButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Check-in" Click="CheckInButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="PT Portfolio" Click="PtPortfolioButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Bookings" Click="BookingsButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="POS" Click="PosButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Thiết bị" Click="EquipmentButton_Click" Padding="16,6" Margin="0,0,8,0"/>
                <TextBlock x:Name="RoleText" Foreground="White" VerticalAlignment="Center" Margin="8,0,20,0"/>
                <Button Content="Logout" Click="LogoutButton_Click" Padding="16,6"/>
            </StackPanel>
        </Border>
        <ContentControl x:Name="ContentHost">
            <views:HomeView/>
        </ContentControl>
    </DockPanel>
</Window>
